AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://elasticmq:9324
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
ARTICLE_AUDIO_QUEUE_URL=http://elasticmq:9324/queue/article-audio-jobs
ARTICLE_AUDIO_JOBS_ROOT=/data/jobs
ARTICLE_AUDIO_SQS_WAIT_TIME_SECONDS=20
ARTICLE_AUDIO_SQS_VISIBILITY_TIMEOUT=300
ARTICLE_AUDIO_IDLE_SLEEP_SECONDS=2
ARTICLE_AUDIO_LOG_LEVEL=INFO
ARTICLE_AUDIO_TTS_BASE_URL=http://host.docker.internal:8888

# Replace or uncomment when wiring Prefect/local execution.
# ARTICLE_AUDIO_HANDOFF_COMMAND=prefect deployment run process-article/process-article --param job_id=$ARTICLE_JOB_ID
