AWS_REGION=us-west-2
AWS_PROFILE=fish
ARTICLE_AUDIO_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/765951922527/article-audio-jobs
ARTICLE_AUDIO_JOBS_ROOT=/data/jobs
ARTICLE_AUDIO_SQS_WAIT_TIME_SECONDS=20
ARTICLE_AUDIO_SQS_VISIBILITY_TIMEOUT=300
ARTICLE_AUDIO_IDLE_SLEEP_SECONDS=2
ARTICLE_AUDIO_LOG_LEVEL=INFO
ARTICLE_AUDIO_TTS_BASE_URL=http://host.docker.internal:8888

PREFECT_API_URL=http://prefect-server:4200/api
ARTICLE_AUDIO_HANDOFF_COMMAND=uv run prefect deployment run url-to-podcast/url-to-podcast --param "url=$$ARTICLE_JOB_URL"
