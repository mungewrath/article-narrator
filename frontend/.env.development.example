# Copy to .env.development and fill in from Terraform outputs.
# Run: cd terraform && terraform output -raw cognito_user_pool_id
#      cd terraform && terraform output -raw cognito_domain
#      cd terraform && terraform output -raw cognito_client_id
#      cd terraform && terraform output -raw api_endpoint
NEXT_PUBLIC_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/<userPoolId>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<clientId>
NEXT_PUBLIC_COGNITO_DOMAIN=<domain>.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_REDIRECT=http://localhost:3000
NEXT_PUBLIC_API_URL=<apiEndpoint>
